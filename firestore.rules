rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only Lise and Clément can access the shared couple space.
    function isAuthorizedUser() {
      return request.auth != null
        && (
          request.auth.uid == "J8xOqDWZv5gEss5CBbQ7kQOsTwV2"
          || request.auth.uid == "o8wLosYoh7b989P9gQyZCk8tt3l1"
        );
    }

    function isValidPersonUid(uid) {
      return uid == "J8xOqDWZv5gEss5CBbQ7kQOsTwV2"
        || uid == "o8wLosYoh7b989P9gQyZCk8tt3l1";
    }

    function hasValidMetadata(data) {
      return isValidPersonUid(data.createdBy)
        && isValidPersonUid(data.updatedBy)
        && data.updatedBy == request.auth.uid;
    }

    function hasValidTransactionShape(data) {
      return data.title is string
        && data.amountEUR is number
        && data.amountEUR >= 0
        && (data.type == "income" || data.type == "expense")
        && (data.recurrence == "one-off" || data.recurrence == "monthly" || data.recurrence == "weekly")
        && isValidPersonUid(data.personUid);
    }

    // Transactions
    match /couples/main/transactions/{transactionId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidTransactionShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidTransactionShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    // Settings (single shared doc)
    match /couples/main/settings/{settingsId} {
      allow read: if isAuthorizedUser();

      allow create, update: if isAuthorizedUser()
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if false;
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
