rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only Lise and Clément can access the shared couple space.
    function isAuthorizedUser() {
      return request.auth != null
        && (
          request.auth.uid == "J8xOqDWZv5gEss5CBbQ7kQOsTwV2"
          || request.auth.uid == "o8wLosYoh7b989P9gQyZCk8tt3l1"
        );
    }

    function isValidPersonUid(uid) {
      return uid == "J8xOqDWZv5gEss5CBbQ7kQOsTwV2"
        || uid == "o8wLosYoh7b989P9gQyZCk8tt3l1";
    }

    function hasValidMetadata(data) {
      return isValidPersonUid(data.createdBy)
        && isValidPersonUid(data.updatedBy)
        && data.updatedBy == request.auth.uid;
    }

    function hasValidTransactionShape(data) {
      return data.title is string
        && data.amountEUR is number
        && data.amountEUR >= 0
        && (data.type == "income" || data.type == "expense")
        && (data.recurrence == "one-off" || data.recurrence == "monthly" || data.recurrence == "weekly")
        && isValidPersonUid(data.personUid);
    }

    // Transactions
    match /couples/main/transactions/{transactionId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidTransactionShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidTransactionShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    // Settings (single shared doc)
    match /couples/main/settings/{settingsId} {
      allow read: if isAuthorizedUser();

      allow create, update: if isAuthorizedUser()
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if false;
    }

    function hasValidChecklistShape(data) {
      return data.label is string
        && data.label.size() > 0
        && data.label.size() <= 200
        && (data.section == "before" || data.section == "arrival" || data.section == "luggage")
        && (data.status == "todo" || data.status == "in-progress" || data.status == "done")
        && data.order is number
        && (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 2000));
    }

    // Voyage checklist (shared sub-collection)
    match /couples/main/checklist/{itemId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidChecklistShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidChecklistShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidTimelineShape(data) {
      return data.label is string
        && data.label.size() > 0
        && data.label.size() <= 200
        && data.date is string
        && data.date.size() == 10
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 2000));
    }

    // Voyage timeline (shared sub-collection)
    match /couples/main/timeline/{itemId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidTimelineShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidTimelineShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidShoppingItemShape(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.aisle is string
        && data.checked is bool
        && (!('quantityLabel' in data) || data.quantityLabel == null || (data.quantityLabel is string && data.quantityLabel.size() <= 40))
        && (!('quantity' in data) || data.quantity == null || (data.quantity is number && data.quantity >= 0))
        && (!('unit' in data) || data.unit == null || (data.unit is string && data.unit.size() <= 20))
        && (!('note' in data) || data.note == null || (data.note is string && data.note.size() <= 500));
    }

    // Shopping list items (shared single list)
    match /couples/main/shoppingItems/{itemId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidShoppingItemShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidShoppingItemShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidCatalogShape(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.nameLower is string
        && data.aisle is string
        && data.favorite is bool
        && data.useCount is number
        && data.useCount >= 0;
    }

    // Shopping catalog (known products: frequents/favorites/remembered aisle)
    match /couples/main/shoppingCatalog/{slug} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidCatalogShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidCatalogShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidPantryItemShape(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.aisle is string
        && (data.status == "ok" || data.status == "low" || data.status == "out")
        && (!('quantityLabel' in data) || data.quantityLabel == null || (data.quantityLabel is string && data.quantityLabel.size() <= 40))
        && (!('quantity' in data) || data.quantity == null || (data.quantity is number && data.quantity >= 0))
        && (!('unit' in data) || data.unit == null || (data.unit is string && data.unit.size() <= 20))
        && (!('note' in data) || data.note == null || (data.note is string && data.note.size() <= 500));
    }

    // Pantry / stock (what we have at home: fridge, cupboards)
    match /couples/main/pantryItems/{itemId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidPantryItemShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidPantryItemShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidRecipeShape(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.ingredients is list
        && data.ingredients.size() <= 50
        && data.steps is list
        && data.steps.size() <= 30
        && (!('note' in data) || data.note == null || (data.note is string && data.note.size() <= 500))
        && (!('imageUrl' in data) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && (!('servings' in data) || data.servings == null || (data.servings is number && data.servings >= 0))
        && (!('prepMinutes' in data) || data.prepMinutes == null || (data.prepMinutes is number && data.prepMinutes >= 0));
    }

    // Recipes (title + ingredients + preparation steps)
    match /couples/main/recipes/{recipeId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidRecipeShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidRecipeShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    function hasValidMealPlanShape(data) {
      return data.date is string
        && data.date.size() == 10
        && (!('midi' in data) || data.midi is list)
        && (!('soir' in data) || data.soir is list);
    }

    // Meal plan (one doc per day; meals tagged per person)
    match /couples/main/mealPlan/{dayId} {
      allow read: if isAuthorizedUser();

      allow create: if isAuthorizedUser()
        && hasValidMealPlanShape(request.resource.data)
        && hasValidMetadata(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthorizedUser()
        && hasValidMealPlanShape(request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if isAuthorizedUser();
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
